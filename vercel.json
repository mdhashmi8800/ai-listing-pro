{
  "framework": null,
  "buildCommand": "",
  "outputDirectory": "public",
  "functions": {
    "api/analyze-image.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/*.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/checkout.html", "dest": "/checkout.html" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
