{
  "framework": null,
  "buildCommand": "",
  "outputDirectory": "public",
  "functions": {
    "api/analyze-image.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/*.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}
