{
  "manifest_version": 3,
  "name": "AI Listing Pro",
  "version": "2.0.0",
  "key": "",
  "description": "AI-Powered Listing Optimization for Meesho Sellers",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "activeTab",
    "identity",
    "scripting",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.meesho.com/*"
      ],
      "js": [
        "config.js",
        "settings.js",
        "supabase.js",
        "supabaseClient.js",
        "authManager.js",
        "meeshoApi.js",
        "ui.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "oauth2": {
    "client_id": "185847449679-mge8gqmdi3bnbsc78iqpdlhh6ph8e7hf.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile"
    ],
    "redirect_uris": [
      "https://mabegbmfmmlmgphgfblcjcalgfepldkm.chromiumapp.org/"
    ]
  },
  "host_permissions": [
    "https://zxborvqzttyofyrksznw.supabase.co/*",
    "https://*.supabase.co/*",
    "https://accounts.google.com/*",
    "https://www.googleapis.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://zxborvqzttyofyrksznw.supabase.co https://*.supabase.co https://www.googleapis.com;"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "popup.html",
        "meeshoApi.js",
        "config.js",
        "supabase.js",
        "styles.css",
        "razorpay.html",
        "Badge/*",
        "icons/*"
      ],
      "matches": [
        "*://*.meesho.com/*"
      ]
    }
  ]
}