<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Listing Pro — Dashboard</title>
  <link rel="stylesheet" href="dashboard.css">
</head>

<body>
  <div class="dashboard-shell">

    <!-- ═══════ LEFT SIDEBAR ═══════ -->
    <aside class="sidebar">
      <!-- Logo -->
      <div class="sidebar-header">
        <div class="sidebar-logo">
          <div class="sidebar-logo-icon">
            <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
            </svg>
          </div>
          <div class="sidebar-logo-text">
            <span class="brand-name">AI Listing Pro</span>
            <span class="brand-sub">Seller Intelligence</span>
          </div>
        </div>
      </div>

      <!-- Navigation -->
      <nav class="sidebar-nav">
        <div class="nav-section-label">Main</div>

        <!-- Overview -->
        <button class="nav-item active" data-page="overview">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          </span>
          Overview
        </button>

        <div class="nav-section-label">AI Tools</div>

        <button class="nav-item" data-page="listing">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24"><path d="M4 5h16v14H4z"/><circle cx="8.5" cy="9" r="1.5"/><path d="M20 16l-5-5-4 4-2-2-5 5"/></svg>
          </span>
          AI Listing Auto Fill
          <span class="nav-badge">1 cr</span>
        </button>

        <!-- Shipping Optimizer -->
        <button class="nav-item" data-page="shipping">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          </span>
          Shipping Optimizer
          <span class="nav-badge">Free</span>
        </button>

        <!-- Profit Calculator -->
        <button class="nav-item" data-page="profit">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </span>
          Profit Calculator
          <span class="nav-badge">1 cr</span>
        </button>

        <!-- Return Analyzer -->
        <button class="nav-item" data-page="returns">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
          </span>
          Return Analyzer
          <span class="nav-badge">1 cr</span>
        </button>

        <!-- Bulk Optimization -->
        <button class="nav-item" data-page="bulk">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
          </span>
          Bulk Optimization
          <span class="nav-badge">Batch</span>
        </button>

        <div class="nav-section-label">Account</div>

        <!-- History -->
        <button class="nav-item" data-page="history">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </span>
          History
        </button>
      </nav>

      <!-- Sidebar Footer -->
      <div class="sidebar-footer">
        <div class="sidebar-credits" id="sidebar-credits">
          <div class="credits-icon">⚡</div>
          <div class="credits-info">
            <div class="credits-count" id="sidebar-credits-count">—</div>
            <div class="credits-label">Credits remaining</div>
          </div>
        </div>
        <div class="sidebar-user" id="sidebar-user">
          <div class="sidebar-user-avatar" id="sidebar-avatar">U</div>
          <div class="sidebar-user-info">
            <div class="sidebar-user-name" id="sidebar-name">Loading...</div>
            <div class="sidebar-user-email" id="sidebar-email">—</div>
          </div>
        </div>
      </div>
    </aside>

    <!-- ═══════ MAIN AREA ═══════ -->
    <main class="main-area">
      <!-- Top Bar -->
      <div class="top-bar">
        <div class="top-bar-title" id="top-bar-title">Overview</div>
        <div class="top-bar-actions">
          <button class="top-bar-btn" id="btn-refresh" title="Refresh data">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            Refresh
          </button>
          <button class="top-bar-btn primary" id="btn-buy-credits">
            ⚡ Buy Credits
          </button>
        </div>
      </div>

      <!-- Dynamic Content Area -->
      <div class="content-area" id="content-area">

        <!-- ═══ OVERVIEW PAGE ═══ -->
        <div class="page-panel active" id="page-overview">
          <!-- Stats -->
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-card-header">
                <div class="stat-card-icon blue">
                  <svg viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                </div>
              </div>
              <div class="stat-card-value" id="ov-credits">—</div>
              <div class="stat-card-label">Credits Remaining</div>
            </div>
            <div class="stat-card">
              <div class="stat-card-header">
                <div class="stat-card-icon green">
                  <svg viewBox="0 0 24 24"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/></svg>
                </div>
              </div>
              <div class="stat-card-value" id="ov-optimizations">—</div>
              <div class="stat-card-label">Total Optimizations</div>
            </div>
            <div class="stat-card">
              <div class="stat-card-header">
                <div class="stat-card-icon purple">
                  <svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                </div>
              </div>
              <div class="stat-card-value" id="ov-plan">—</div>
              <div class="stat-card-label">Current Plan</div>
            </div>
            <div class="stat-card">
              <div class="stat-card-header">
                <div class="stat-card-icon orange">
                  <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
              </div>
              <div class="stat-card-value" id="ov-saved">₹0</div>
              <div class="stat-card-label">Estimated Savings</div>
            </div>
          </div>

          <!-- Quick Actions -->
          <div class="quick-actions-section">
            <div class="section-heading">Quick Actions</div>
            <div class="quick-actions-grid">
              <div class="quick-action-card" data-navigate="listing">
                <div class="quick-action-icon purple">
                  <svg viewBox="0 0 24 24"><path d="M4 5h16v14H4z"/><circle cx="8.5" cy="9" r="1.5"/><path d="M20 16l-5-5-4 4-2-2-5 5"/></svg>
                </div>
                <h3>AI Listing Auto Fill</h3>
                <p>Upload a product image and generate title, category, keywords, tags and description in one step</p>
                <span class="quick-action-cost">1 Credit</span>
              </div>
              <div class="quick-action-card" data-navigate="shipping">
                <div class="quick-action-icon green">
                  <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                </div>
                <h3>Shipping Optimizer</h3>
                <p>Reduce delivery costs with AI-powered shipping analysis</p>
                <span class="quick-action-cost free">Free</span>
              </div>
              <div class="quick-action-card" data-navigate="profit">
                <div class="quick-action-icon blue">
                  <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                </div>
                <h3>Profit Calculator</h3>
                <p>Analyze margins, commissions &amp; net profit per product</p>
                <span class="quick-action-cost">1 Credit</span>
              </div>
              <div class="quick-action-card" data-navigate="returns">
                <div class="quick-action-icon orange">
                  <svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
                </div>
                <h3>Return Analyzer</h3>
                <p>Identify return patterns and reduce RTO losses</p>
                <span class="quick-action-cost">1 Credit</span>
              </div>
              <div class="quick-action-card" data-navigate="bulk">
                <div class="quick-action-icon warning">
                  <svg viewBox="0 0 24 24"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
                </div>
                <h3>Bulk Listing Generator</h3>
                <p>Generate marketplace-ready titles, categories, keywords and tags for multiple products at once</p>
                <span class="quick-action-cost">Batch</span>
              </div>
            </div>
          </div>

          <!-- Recent Activity -->
          <div class="activity-section">
            <div class="section-heading">Recent Activity</div>
            <div class="activity-list" id="activity-list">
              <div class="empty-state">
                <div class="empty-state-icon">
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <h3>No activity yet</h3>
                <p>Run your first analysis to see results here</p>
              </div>
            </div>
          </div>
        </div>

        <!-- ═══ AI LISTING AUTO FILL PAGE ═══ -->
        <div class="page-panel" id="page-listing">
          <div class="tool-header">
            <div class="tool-header-icon" style="background: var(--dash-purple-light); color: var(--dash-purple);">
              <svg viewBox="0 0 24 24"><path d="M4 5h16v14H4z"/><circle cx="8.5" cy="9" r="1.5"/><path d="M20 16l-5-5-4 4-2-2-5 5"/></svg>
            </div>
            <div class="tool-header-text">
              <h2>AI Listing Auto Fill</h2>
              <p>Upload one product image and generate a ready-to-publish Meesho listing draft</p>
            </div>
          </div>

          <div class="dash-card">
            <div class="dash-card-title">🧠 Image-Led Listing Generator</div>
            <div class="dash-input-group">
              <label class="dash-label">Product Image</label>
              <input class="dash-input" type="file" id="listing-image" accept="image/*">
            </div>
            <div class="dash-input-row">
              <div class="dash-input-group">
                <label class="dash-label">Product Hints (optional)</label>
                <input class="dash-input" type="text" id="listing-hints" placeholder="e.g. rayon kurti printed festive wear">
              </div>
              <div class="dash-input-group">
                <label class="dash-label">Target Buyer</label>
                <select class="dash-select" id="listing-audience">
                  <option value="auto" selected>Auto detect</option>
                  <option value="Women">Women</option>
                  <option value="Men">Men</option>
                  <option value="Kids">Kids</option>
                  <option value="Home">Home</option>
                  <option value="Beauty">Beauty</option>
                </select>
              </div>
            </div>
            <div class="dash-input-row">
              <div class="dash-input-group">
                <label class="dash-label">Selling Price Goal (₹)</label>
                <input class="dash-input" type="number" id="listing-price-goal" placeholder="e.g. 499">
              </div>
              <div class="dash-input-group">
                <label class="dash-label">Listing Tone</label>
                <select class="dash-select" id="listing-tone">
                  <option value="balanced" selected>Balanced</option>
                  <option value="seo">SEO focused</option>
                  <option value="premium">Premium feel</option>
                  <option value="conversion">High conversion</option>
                </select>
              </div>
            </div>
            <div class="listing-preview-shell hidden" id="listing-preview-shell">
              <img id="listing-preview-image" class="listing-preview-image" alt="Uploaded product preview">
              <div class="listing-preview-copy" id="listing-preview-copy">Upload an image to preview listing cues.</div>
            </div>
            <button class="dash-btn-run" id="btn-run-listing" style="width: 100%; margin-top: 8px;">
              🧠 Generate Listing Draft — 1 Credit
            </button>
          </div>
          <div class="result-box" id="result-listing"></div>
        </div>

        <!-- ═══ SHIPPING OPTIMIZER PAGE ═══ -->
        <div class="page-panel" id="page-shipping">
          <div class="tool-header">
            <div class="tool-header-icon" style="background: var(--dash-accent-light); color: var(--dash-accent);">
              <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            </div>
            <div class="tool-header-text">
              <h2>Shipping Optimizer</h2>
              <p>Analyze delivery costs and get AI recommendations to reduce shipping expenses</p>
            </div>
          </div>

          <div class="dash-card">
            <div class="dash-card-title">📦 Product Details</div>
            <div class="dash-input-group">
              <label class="dash-label">Product Name / URL</label>
              <input class="dash-input" type="text" id="ship-product" placeholder="Enter Meesho product name or URL">
            </div>
            <div class="dash-input-row">
              <div class="dash-input-group">
                <label class="dash-label">Product Weight (grams)</label>
                <input class="dash-input" type="number" id="ship-weight" placeholder="e.g. 250">
              </div>
              <div class="dash-input-group">
                <label class="dash-label">Pincode (Origin)</label>
                <input class="dash-input" type="text" id="ship-pincode" placeholder="e.g. 110001">
              </div>
            </div>
            <div class="dash-input-group">
              <label class="dash-label">Current Shipping Cost (₹)</label>
              <input class="dash-input" type="number" id="ship-cost" placeholder="e.g. 45">
            </div>
            <button class="dash-btn-run" id="btn-run-shipping" style="width: 100%; margin-top: 8px;">
              🚀 Run Shipping Analysis — Free
            </button>
          </div>
          <div class="result-box" id="result-shipping"></div>
        </div>

        <!-- ═══ PROFIT CALCULATOR PAGE ═══ -->
        <div class="page-panel" id="page-profit">
          <div class="tool-header">
            <div class="tool-header-icon" style="background: var(--dash-primary-light); color: var(--dash-primary);">
              <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <div class="tool-header-text">
              <h2>Profit Calculator</h2>
              <p>Calculate exact profit margins after Meesho commission, shipping &amp; GST</p>
            </div>
          </div>

          <div class="dash-card">
            <div class="dash-card-title">💰 Enter Product Financials</div>
            <div class="dash-input-row">
              <div class="dash-input-group">
                <label class="dash-label">Selling Price (₹)</label>
                <input class="dash-input" type="number" id="profit-selling" placeholder="e.g. 499">
              </div>
              <div class="dash-input-group">
                <label class="dash-label">Product Cost (₹)</label>
                <input class="dash-input" type="number" id="profit-cost" placeholder="e.g. 200">
              </div>
            </div>
            <div class="dash-input-row">
              <div class="dash-input-group">
                <label class="dash-label">Weight (grams)</label>
                <input class="dash-input" type="number" id="profit-weight" placeholder="e.g. 350">
              </div>
              <div class="dash-input-group">
                <label class="dash-label">Category</label>
                <select class="dash-select" id="profit-category">
                  <option value="women_ethnic" selected>Women Ethnic Wear</option>
                  <option value="fashion">Fashion & Apparel</option>
                  <option value="beauty">Beauty & Personal Care</option>
                  <option value="home">Home & Kitchen</option>
                  <option value="electronics">Electronics & Accessories</option>
                  <option value="jewelry">Jewelry & Accessories</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </div>
            <div class="dash-input-row">
              <div class="dash-input-group">
                <label class="dash-label">Packaging / Handling (₹)</label>
                <input class="dash-input" type="number" id="profit-packaging" placeholder="e.g. 12">
              </div>
              <div class="dash-input-group">
                <label class="dash-label">Commission Override % (optional)</label>
                <input class="dash-input" type="number" id="profit-commission-override" placeholder="Auto from category" step="0.1">
              </div>
            </div>
            <div class="dash-input-row">
              <div class="dash-input-group">
                <label class="dash-label">GST %</label>
                <select class="dash-select" id="profit-gst">
                  <option value="0">0% (Exempted)</option>
                  <option value="5" selected>5%</option>
                  <option value="12">12%</option>
                  <option value="18">18%</option>
                  <option value="28">28%</option>
                </select>
              </div>
              <div class="dash-input-group">
                <label class="dash-label">Target Profit Margin %</label>
                <input class="dash-input" type="number" id="profit-target-margin" placeholder="e.g. 18" value="18" step="0.1">
              </div>
            </div>
            <div class="dash-helper-text">Commission and shipping are auto-estimated from Meesho-style category and weight slabs.</div>
            <button class="dash-btn-run" id="btn-run-profit" style="width: 100%; margin-top: 8px;">
              📊 Calculate Profit — 1 Credit
            </button>
          </div>
          <div class="result-box" id="result-profit"></div>
        </div>

        <!-- ═══ RETURN ANALYZER PAGE ═══ -->
        <div class="page-panel" id="page-returns">
          <div class="tool-header">
            <div class="tool-header-icon" style="background: var(--dash-orange-light); color: var(--dash-orange);">
              <svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
            </div>
            <div class="tool-header-text">
              <h2>Return Analyzer</h2>
              <p>Understand why products get returned and get AI suggestions to reduce RTO</p>
            </div>
          </div>

          <div class="dash-card">
            <div class="dash-card-title">📦 Return Details</div>
            <div class="dash-input-group">
              <label class="dash-label">Product Category</label>
              <select class="dash-select" id="return-category">
                <option value="">Select category</option>
                <option value="clothing">Clothing & Fashion</option>
                <option value="electronics">Electronics & Accessories</option>
                <option value="home">Home & Kitchen</option>
                <option value="beauty">Beauty & Personal Care</option>
                <option value="footwear">Footwear</option>
                <option value="jewelry">Jewelry & Accessories</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="dash-input-row">
              <div class="dash-input-group">
                <label class="dash-label">Total Orders (Last 30 days)</label>
                <input class="dash-input" type="number" id="return-orders" placeholder="e.g. 150">
              </div>
              <div class="dash-input-group">
                <label class="dash-label">Total Returns (Last 30 days)</label>
                <input class="dash-input" type="number" id="return-returns" placeholder="e.g. 23">
              </div>
            </div>
            <div class="dash-input-group">
              <label class="dash-label">Common Return Reasons (optional)</label>
              <textarea class="dash-textarea" id="return-reasons" placeholder="e.g. Size mismatch, color different from image, quality issues..."></textarea>
            </div>
            <button class="dash-btn-run" id="btn-run-returns" style="width: 100%; margin-top: 8px;">
              🔍 Analyze Returns — 1 Credit
            </button>
          </div>
          <div class="result-box" id="result-returns"></div>
        </div>

        <!-- ═══ BULK OPTIMIZATION PAGE ═══ -->
        <div class="page-panel" id="page-bulk">
          <div class="tool-header">
            <div class="tool-header-icon" style="background: var(--dash-purple-light); color: var(--dash-purple);">
              <svg viewBox="0 0 24 24"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
            </div>
            <div class="tool-header-text">
              <h2>Bulk Listing Generator</h2>
              <p>Generate titles, categories, keywords and tags for multiple products at once</p>
            </div>
          </div>

          <div class="dash-card">
            <div class="dash-card-title">📋 Bulk Product Data</div>
            <div class="dash-input-group">
              <label class="dash-label">Paste Product Seeds (one per line)</label>
              <textarea class="dash-textarea" id="bulk-products" style="min-height: 180px;" placeholder="red kurti | rayon | printed | festive&#10;blue t-shirt | cotton | oversized | men&#10;steel bottle | 1 litre | leakproof | gym"></textarea>
            </div>
            <div class="dash-input-group">
              <label class="dash-label">Output Focus</label>
              <select class="dash-select" id="bulk-focus">
                <option value="titles">Title-led</option>
                <option value="seo">SEO-heavy</option>
                <option value="catalog">Catalog cleanup</option>
                <option value="all">Full listing pack</option>
              </select>
            </div>
            <button class="dash-btn-run" id="btn-run-bulk" style="width: 100%; margin-top: 8px;">
              ⚡ Generate Bulk Listings — 1 Credit per product
            </button>
          </div>
          <div class="result-box" id="result-bulk"></div>
        </div>

        <!-- ═══ HISTORY PAGE ═══ -->
        <div class="page-panel" id="page-history">
          <div class="tool-header">
            <div class="tool-header-icon" style="background: var(--dash-primary-light); color: var(--dash-primary);">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="tool-header-text">
              <h2>History</h2>
              <p>View all past analyses and optimization results</p>
            </div>
          </div>

          <div class="dash-card" style="padding: 0; overflow: hidden;">
            <div id="history-content">
              <div class="empty-state">
                <div class="empty-state-icon">
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <h3>No history yet</h3>
                <p>Your analysis results will appear here after you run your first optimization</p>
              </div>
            </div>
          </div>
        </div>

      </div><!-- /content-area -->
    </main>
  </div><!-- /dashboard-shell -->

  <!-- Login Overlay (shown if not logged in) -->
  <div class="login-overlay hidden" id="login-overlay">
    <div class="login-card">
      <h2>🔒 Please Sign In</h2>
      <p>Open the AI Listing Pro popup and sign in with Google to access the dashboard.</p>
      <button class="dash-btn dash-btn-primary dash-btn-lg" id="btn-login-redirect">Open Extension Popup</button>
    </div>
  </div>

  <!-- Scripts -->
  <script src="config.js"></script>
  <script src="supabase.js"></script>
  <script src="supabaseClient.js"></script>
  <script src="dashboard.js"></script>
</body>

</html>
