  const MATERIAL_PATTERNS = [
    { key: 'rayon', label: 'Rayon', patterns: ['rayon'] },
    { key: 'cotton', label: 'Cotton', patterns: ['cotton'] },
    { key: 'silk', label: 'Silk', patterns: ['silk'] },
    { key: 'georgette', label: 'Georgette', patterns: ['georgette'] },
