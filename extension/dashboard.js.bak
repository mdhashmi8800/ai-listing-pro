    listingTone: document.getElementById('listing-tone'),
    listingPreviewShell: document.getElementById('listing-preview-shell'),
    listingPreviewImage: document.getElementById('listing-preview-image'),
    listingPreviewCopy: document.getElementById('listing-preview-copy'),
  };

  // ── Page Title Map ──
  const PAGE_TITLES = {
    overview: 'Overview',
    listing: 'AI Listing Auto Fill',
    shipping: 'Shipping Optimizer',
    profit: 'Profit Calculator',
    returns: 'Return Analyzer',
    bulk: 'Bulk Listing Generator',
