      category: 'Home & Kitchen > Bedsheets',
      audience: 'Home',
      patterns: ['bedsheet', 'bed sheet', 'comforter', 'blanket'],
      tags: ['home linen', 'bedroom', 'soft fabric']
    },
    {
      key: 'bottle',
      title: 'Bottle',
      category: 'Home & Kitchen > Bottles',
      audience: 'Home',
      patterns: ['bottle', 'flask', 'sipper', 'tumbler'],
