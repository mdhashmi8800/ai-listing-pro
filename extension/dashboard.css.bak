/* AI Dashboard - Professional SaaS UI */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

/* ════════════════════════════════════════
   DESIGN TOKENS
══════════════════════════════════════════ */
:root {
  --dash-primary: #2563EB;
  --dash-primary-hover: #1D4ED8;
  --dash-primary-light: #EFF6FF;
  --dash-primary-subtle: #DBEAFE;
  --dash-accent: #10B981;
  --dash-accent-hover: #059669;
  --dash-accent-light: #ECFDF5;
  --dash-purple: #7C3AED;
  --dash-purple-light: #F5F3FF;
  --dash-warning: #F59E0B;
  --dash-warning-light: #FFFBEB;
  --dash-danger: #EF4444;
  --dash-danger-light: #FEF2F2;
  --dash-orange: #F97316;
  --dash-orange-light: #FFF7ED;

  --dash-bg: #F1F5F9;
  --dash-surface: #FFFFFF;
  --dash-surface-hover: #F8FAFC;

  --dash-text: #0F172A;
  --dash-text-secondary: #475569;
  --dash-text-muted: #94A3B8;

  --dash-border: #E2E8F0;
  --dash-border-strong: #CBD5E1;

  --dash-sidebar-bg: #0F172A;
  --dash-sidebar-text: #CBD5E1;
  --dash-sidebar-hover: #1E293B;
  --dash-sidebar-active: #2563EB;

  --dash-radius-sm: 6px;
  --dash-radius-md: 10px;
  --dash-radius-lg: 14px;
  --dash-radius-xl: 18px;

  --dash-shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
  --dash-shadow-md: 0 4px 12px rgba(0, 0, 0, 0.08);
  --dash-shadow-lg: 0 10px 30px rgba(0, 0, 0, 0.1);

  --dash-font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  --dash-transition: all 0.2s ease;
}

/* ════════════════════════════════════════
   RESET & BASE
══════════════════════════════════════════ */
*, *::before, *::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html, body {
  height: 100%;
  font-family: var(--dash-font);
  font-size: 14px;
  color: var(--dash-text);
  background: var(--dash-bg);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ════════════════════════════════════════
   LAYOUT
══════════════════════════════════════════ */
.dashboard-shell {
  display: flex;
  height: 100vh;
  overflow: hidden;
}

/* ════════════════════════════════════════
   SIDEBAR
══════════════════════════════════════════ */
.sidebar {
  width: 260px;
  min-width: 260px;
  background: var(--dash-sidebar-bg);
  display: flex;
  flex-direction: column;
  border-right: 1px solid rgba(255, 255, 255, 0.06);
  z-index: 10;
}

.sidebar-header {
  padding: 24px 20px 20px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.sidebar-logo {
  display: flex;
  align-items: center;
  gap: 12px;
  text-decoration: none;
}

.sidebar-logo-icon {
  width: 38px;
  height: 38px;
  background: var(--dash-primary);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.sidebar-logo-icon svg {
  width: 20px;
  height: 20px;
  stroke: #fff;
  fill: none;
}

.sidebar-logo-text {
  display: flex;
  flex-direction: column;
}

.sidebar-logo-text .brand-name {
  font-size: 16px;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: -0.3px;
}

.sidebar-logo-text .brand-sub {
  font-size: 11px;
  color: var(--dash-sidebar-text);
  font-weight: 400;
  margin-top: 1px;
}

/* Sidebar Navigation */
.sidebar-nav {
  flex: 1;
  padding: 16px 12px;
  overflow-y: auto;
}

.sidebar-nav::-webkit-scrollbar {
  width: 4px;
}

.sidebar-nav::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4px;
}

.nav-section-label {
  font-size: 10px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: rgba(148, 163, 184, 0.6);
  padding: 16px 12px 8px;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 14px;
  border-radius: var(--dash-radius-md);
  cursor: pointer;
  transition: var(--dash-transition);
  color: var(--dash-sidebar-text);
  font-size: 13.5px;
  font-weight: 500;
  border: none;
  background: none;
  width: 100%;
  text-align: left;
  position: relative;
}

.nav-item:hover {
  background: var(--dash-sidebar-hover);
  color: #FFFFFF;
}

.nav-item.active {
  background: var(--dash-sidebar-active);
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 2px 8px rgba(37, 99, 235, 0.3);
}

.nav-item .nav-icon {
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.nav-item .nav-icon svg {
  width: 18px;
  height: 18px;
  stroke: currentColor;
  stroke-width: 1.75;
  fill: none;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.nav-item .nav-badge {
  margin-left: auto;
  font-size: 10px;
  font-weight: 700;
  padding: 2px 7px;
  border-radius: 20px;
  background: rgba(37, 99, 235, 0.2);
  color: #60A5FA;
}

.nav-item.active .nav-badge {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}

/* Sidebar Footer */
.sidebar-footer {
  padding: 16px 12px;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.sidebar-credits {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 14px;
  background: rgba(37, 99, 235, 0.12);
  border-radius: var(--dash-radius-md);
  border: 1px solid rgba(37, 99, 235, 0.2);
}

.sidebar-credits .credits-icon {
  width: 32px;
  height: 32px;
  background: var(--dash-primary);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  flex-shrink: 0;
}

.sidebar-credits .credits-info {
  flex: 1;
}

.sidebar-credits .credits-count {
  font-size: 16px;
  font-weight: 700;
  color: #FFFFFF;
}

.sidebar-credits .credits-label {
  font-size: 11px;
  color: var(--dash-sidebar-text);
}

.sidebar-credits.low {
  background: rgba(239, 68, 68, 0.12);
  border-color: rgba(239, 68, 68, 0.25);
}

.sidebar-credits.low .credits-icon {
  background: var(--dash-danger);
}

.sidebar-user {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  margin-top: 8px;
  border-radius: var(--dash-radius-md);
  cursor: pointer;
  transition: var(--dash-transition);
}

.sidebar-user:hover {
  background: var(--dash-sidebar-hover);
}

.sidebar-user-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--dash-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 13px;
  color: #fff;
  flex-shrink: 0;
}

.sidebar-user-info {
  flex: 1;
  min-width: 0;
}

.sidebar-user-name {
  font-size: 13px;
  font-weight: 600;
  color: #FFFFFF;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sidebar-user-email {
  font-size: 11px;
  color: var(--dash-sidebar-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ════════════════════════════════════════
   MAIN CONTENT AREA
══════════════════════════════════════════ */
.main-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* Top Bar */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 32px;
  background: var(--dash-surface);
  border-bottom: 1px solid var(--dash-border);
  min-height: 64px;
}

.top-bar-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--dash-text);
}

.top-bar-actions {
  display: flex;
  align-items: center;
  gap: 12px;
}

.top-bar-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  font-size: 13px;
  font-weight: 600;
  border-radius: var(--dash-radius-sm);
  border: 1px solid var(--dash-border);
  background: var(--dash-surface);
  color: var(--dash-text-secondary);
  cursor: pointer;
  transition: var(--dash-transition);
  font-family: var(--dash-font);
}

.top-bar-btn:hover {
  background: var(--dash-surface-hover);
  border-color: var(--dash-border-strong);
}

.top-bar-btn.primary {
  background: var(--dash-primary);
  color: #fff;
  border-color: var(--dash-primary);
}

.top-bar-btn.primary:hover {
  background: var(--dash-primary-hover);
}

/* Content Container */
.content-area {
  flex: 1;
  overflow-y: auto;
  padding: 32px;
}

.content-area::-webkit-scrollbar {
  width: 6px;
}

.content-area::-webkit-scrollbar-thumb {
  background: var(--dash-border-strong);
  border-radius: 6px;
}

/* ════════════════════════════════════════
   OVERVIEW PAGE
══════════════════════════════════════════ */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  margin-bottom: 32px;
}

.stat-card {
  background: var(--dash-surface);
  border: 1px solid var(--dash-border);
  border-radius: var(--dash-radius-lg);
  padding: 22px;
  transition: var(--dash-transition);
}

.stat-card:hover {
  box-shadow: var(--dash-shadow-md);
  border-color: var(--dash-border-strong);
}

.stat-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.stat-card-icon {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stat-card-icon.blue { background: var(--dash-primary-light); color: var(--dash-primary); }
.stat-card-icon.green { background: var(--dash-accent-light); color: var(--dash-accent); }
.stat-card-icon.purple { background: var(--dash-purple-light); color: var(--dash-purple); }
.stat-card-icon.orange { background: var(--dash-orange-light); color: var(--dash-orange); }

.stat-card-icon svg {
  width: 20px;
  height: 20px;
  stroke: currentColor;
  stroke-width: 2;
  fill: none;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.stat-card-trend {
  font-size: 11px;
  font-weight: 600;
  padding: 3px 8px;
  border-radius: 20px;
}

.stat-card-trend.up {
  background: var(--dash-accent-light);
  color: var(--dash-accent);
}

.stat-card-trend.down {
  background: var(--dash-danger-light);
  color: var(--dash-danger);
}

.stat-card-value {
  font-size: 28px;
  font-weight: 800;
  color: var(--dash-text);
  line-height: 1;
  margin-bottom: 4px;
}

.stat-card-label {
  font-size: 12px;
  color: var(--dash-text-muted);
  font-weight: 500;
}

/* Quick Actions */
.quick-actions-section {
  margin-bottom: 32px;
}

.section-heading {
  font-size: 16px;
  font-weight: 700;
  color: var(--dash-text);
  margin-bottom: 16px;
}

.quick-actions-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16px;
}

.quick-action-card {
  background: var(--dash-surface);
  border: 1px solid var(--dash-border);
  border-radius: var(--dash-radius-lg);
  padding: 24px;
  cursor: pointer;
  transition: var(--dash-transition);
  text-align: left;
}

.quick-action-card:hover {
  border-color: var(--dash-primary);
  box-shadow: 0 4px 16px rgba(37, 99, 235, 0.1);
  transform: translateY(-2px);
}

.quick-action-icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}

.quick-action-icon.blue { background: var(--dash-primary-light); color: var(--dash-primary); }
.quick-action-icon.green { background: var(--dash-accent-light); color: var(--dash-accent); }
.quick-action-icon.purple { background: var(--dash-purple-light); color: var(--dash-purple); }
.quick-action-icon.orange { background: var(--dash-orange-light); color: var(--dash-orange); }
.quick-action-icon.warning { background: var(--dash-warning-light); color: var(--dash-warning); }
.quick-action-icon.danger { background: var(--dash-danger-light); color: var(--dash-danger); }

.quick-action-icon svg {
  width: 24px;
  height: 24px;
  stroke: currentColor;
  stroke-width: 1.75;
  fill: none;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.quick-action-card h3 {
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 6px;
  color: var(--dash-text);
}

.quick-action-card p {
  font-size: 12px;
  color: var(--dash-text-muted);
  line-height: 1.5;
}

.quick-action-cost {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  margin-top: 12px;
  font-size: 11px;
  font-weight: 600;
  padding: 3px 10px;
  border-radius: 20px;
  background: var(--dash-primary-light);
  color: var(--dash-primary);
}

.quick-action-cost.free {
  background: var(--dash-accent-light);
  color: var(--dash-accent);
}

/* Recent Activity */
.activity-section {
  margin-bottom: 32px;
}

.activity-list {
  background: var(--dash-surface);
  border: 1px solid var(--dash-border);
  border-radius: var(--dash-radius-lg);
  overflow: hidden;
}

.activity-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 16px 20px;
  border-bottom: 1px solid var(--dash-border);
  transition: var(--dash-transition);
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-item:hover {
  background: var(--dash-surface-hover);
}

.activity-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.activity-dot.blue { background: var(--dash-primary); }
.activity-dot.green { background: var(--dash-accent); }
.activity-dot.purple { background: var(--dash-purple); }
.activity-dot.orange { background: var(--dash-orange); }

.activity-text {
  flex: 1;
  font-size: 13px;
  color: var(--dash-text-secondary);
}

.activity-text strong {
  color: var(--dash-text);
  font-weight: 600;
}

.activity-time {
  font-size: 11px;
  color: var(--dash-text-muted);
  white-space: nowrap;
}

/* ════════════════════════════════════════
   PAGE PANELS (Shared)
══════════════════════════════════════════ */
.page-panel {
  display: none;
  animation: fadeIn 0.25s ease;
}

.page-panel.active {
  display: block;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Tool Page Header */
.tool-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 28px;
}

.tool-header-icon {
  width: 56px;
  height: 56px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tool-header-icon svg {
  width: 28px;
  height: 28px;
  stroke: currentColor;
  stroke-width: 1.75;
  fill: none;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.tool-header-text h2 {
  font-size: 22px;
  font-weight: 700;
  color: var(--dash-text);
  margin-bottom: 4px;
}

.tool-header-text p {
  font-size: 13px;
  color: var(--dash-text-muted);
}

/* Cards & Forms */
.dash-card {
  background: var(--dash-surface);
  border: 1px solid var(--dash-border);
  border-radius: var(--dash-radius-lg);
  padding: 24px;
  margin-bottom: 20px;
}

.dash-card-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--dash-text);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.dash-label {
  display: block;
  font-size: 12px;
  font-weight: 600;
  color: var(--dash-text-secondary);
  margin-bottom: 6px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.dash-input,
.dash-textarea,
.dash-select {
  width: 100%;
  padding: 10px 14px;
  font-size: 13px;
  font-family: var(--dash-font);
  border: 1px solid var(--dash-border);
  border-radius: var(--dash-radius-sm);
  background: var(--dash-surface);
  color: var(--dash-text);
  transition: var(--dash-transition);
  outline: none;
}

.dash-input:focus,
.dash-textarea:focus,
.dash-select:focus {
  border-color: var(--dash-primary);
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

.dash-textarea {
  min-height: 120px;
  resize: vertical;
  line-height: 1.6;
}

.dash-input-group {
  margin-bottom: 16px;
}

.dash-input-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.dash-helper-text {
  font-size: 12px;
  color: var(--dash-text-muted);
  margin-top: -4px;
  margin-bottom: 8px;
}

/* Buttons */
.dash-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 10px 20px;
  font-size: 13px;
  font-weight: 600;
  font-family: var(--dash-font);
  border-radius: var(--dash-radius-sm);
  border: none;
  cursor: pointer;
  transition: var(--dash-transition);
}

.dash-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.dash-btn-primary {
  background: var(--dash-primary);
  color: #fff;
}

.dash-btn-primary:hover:not(:disabled) {
  background: var(--dash-primary-hover);
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
}

.dash-btn-success {
  background: var(--dash-accent);
  color: #fff;
}

.dash-btn-success:hover:not(:disabled) {
  background: var(--dash-accent-hover);
}

.dash-btn-outline {
  background: var(--dash-surface);
  color: var(--dash-text-secondary);
  border: 1px solid var(--dash-border);
}

.dash-btn-outline:hover:not(:disabled) {
  background: var(--dash-surface-hover);
  border-color: var(--dash-border-strong);
}

.dash-btn-lg {
  padding: 14px 28px;
  font-size: 15px;
  border-radius: var(--dash-radius-md);
}

.dash-btn-run {
  background: linear-gradient(135deg, #2563EB 0%, #7C3AED 100%);
  color: #fff;
  padding: 14px 28px;
  font-size: 14px;
  font-weight: 700;
  border-radius: var(--dash-radius-md);
  border: none;
  cursor: pointer;
  transition: var(--dash-transition);
  box-shadow: 0 4px 14px rgba(37, 99, 235, 0.35);
}

.dash-btn-run:hover:not(:disabled) {
  transform: translateY(-1px);
  box-shadow: 0 6px 20px rgba(37, 99, 235, 0.45);
}

.dash-btn-run:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}

/* Results */
.result-box {
  background: var(--dash-surface-hover);
  border: 1px solid var(--dash-border);
  border-radius: var(--dash-radius-md);
  padding: 20px;
  margin-top: 16px;
  font-size: 13px;
  line-height: 1.7;
  color: var(--dash-text-secondary);
  white-space: pre-wrap;
  display: none;
}

.result-box.active {
  display: block;
  animation: fadeIn 0.3s ease;
}

.result-box h4 {
  font-size: 14px;
  font-weight: 600;
  color: var(--dash-text);
  margin-bottom: 8px;
}

.listing-preview-shell {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 16px;
  align-items: center;
  margin-top: 8px;
  padding: 14px;
  border: 1px dashed var(--dash-border-strong);
  border-radius: var(--dash-radius-md);
  background: var(--dash-surface-hover);
}

.listing-preview-image {
  width: 120px;
  height: 120px;
  object-fit: cover;
  border-radius: var(--dash-radius-md);
  border: 1px solid var(--dash-border);
}

.listing-preview-copy {
  font-size: 13px;
  color: var(--dash-text-secondary);
  line-height: 1.6;
}

.insight-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
  margin-bottom: 14px;
}

.insight-card {
  background: var(--dash-surface);
  border: 1px solid var(--dash-border);
  border-radius: var(--dash-radius-md);
  padding: 14px;
}

.insight-card.emphasis {
  background: linear-gradient(135deg, #eff6ff 0%, #f5f3ff 100%);
  border-color: rgba(124, 58, 237, 0.25);
}

.insight-card strong {
  display: block;
  font-size: 16px;
  color: var(--dash-text);
  margin-bottom: 4px;
}

.insight-card small {
  display: block;
  color: var(--dash-text-muted);
  line-height: 1.5;
}

.insight-label {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--dash-text-muted);
  margin-bottom: 8px;
}

.result-section-card {
  background: var(--dash-surface);
  border: 1px solid var(--dash-border);
  border-radius: var(--dash-radius-md);
  padding: 16px;
  margin-top: 12px;
}

.section-title {
  font-size: 13px;
  font-weight: 700;
  color: var(--dash-text);
  margin-bottom: 12px;
}

.result-metric-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 9px 0;
  border-bottom: 1px solid var(--dash-border);
}

.result-metric-row:last-child {
  border-bottom: none;
}

.result-metric-row span {
  color: var(--dash-text-secondary);
}

.result-metric-row strong {
  color: var(--dash-text);
  text-align: right;
}

.result-metric-row.total {
  padding-top: 12px;
}

.result-metric-row.total strong {
  font-size: 16px;
}

.result-note {
  margin-top: 10px;
  color: var(--dash-text-secondary);
  line-height: 1.7;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.result-chip {
  display: inline-flex;
  align-items: center;
  padding: 6px 10px;
  border-radius: 999px;
  background: var(--dash-primary-light);
  color: var(--dash-primary);
  font-size: 12px;
  font-weight: 600;
}

.bulk-result-card {
  margin-top: 12px;
  padding: 16px;
  border-radius: var(--dash-radius-md);
  border: 1px solid var(--dash-border);
  background: var(--dash-surface);
}

.bulk-result-head {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 12px;
}

.bulk-index {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--dash-primary-light);
  color: var(--dash-primary);
  font-size: 12px;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bulk-source {
  margin-top: 4px;
  color: var(--dash-text-muted);
  font-size: 12px;
}

.bulk-meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
  margin-bottom: 12px;
}

.bulk-meta-grid span {
  display: block;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--dash-text-muted);
  margin-bottom: 4px;
}

.bulk-meta-grid strong {
  display: block;
  color: var(--dash-text);
  line-height: 1.5;
}

/* Loading */
.dash-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px;
  color: var(--dash-text-muted);
  gap: 12px;
}

.dash-spinner {
  width: 36px;
  height: 36px;
  border: 3px solid var(--dash-border);
  border-top-color: var(--dash-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Toast */
.dash-toast {
  position: fixed;
  top: 20px;
  right: 20px;
  padding: 14px 20px;
  border-radius: var(--dash-radius-md);
  font-size: 13px;
  font-weight: 500;
  font-family: var(--dash-font);
  z-index: 1000;
  max-width: 400px;
  box-shadow: var(--dash-shadow-lg);
  animation: slideInRight 0.3s ease;
  display: flex;
  align-items: center;
  gap: 10px;
}

@keyframes slideInRight {
  from { opacity: 0; transform: translateX(40px); }
  to { opacity: 1; transform: translateX(0); }
}

.dash-toast.success {
  background: var(--dash-accent-light);
  border: 1px solid var(--dash-accent);
  color: #065F46;
}

.dash-toast.error {
  background: var(--dash-danger-light);
  border: 1px solid var(--dash-danger);
  color: #991B1B;
}

.dash-toast.info {
  background: var(--dash-primary-light);
  border: 1px solid var(--dash-primary);
  color: #1E40AF;
}

/* Empty State */
.empty-state {
  text-align: center;
  padding: 60px 40px;
  color: var(--dash-text-muted);
}

.empty-state-icon {
  width: 64px;
  height: 64px;
  margin: 0 auto 16px;
  background: var(--dash-bg);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-state-icon svg {
  width: 28px;
  height: 28px;
  stroke: var(--dash-text-muted);
  stroke-width: 1.5;
  fill: none;
}

.empty-state h3 {
  font-size: 16px;
  font-weight: 600;
  color: var(--dash-text-secondary);
  margin-bottom: 6px;
}

.empty-state p {
  font-size: 13px;
  line-height: 1.5;
  max-width: 360px;
  margin: 0 auto;
}

/* ════════════════════════════════════════
   TABLES (for History, Bulk, etc.)
══════════════════════════════════════════ */
.dash-table {
  width: 100%;
  border-collapse: collapse;
}

.dash-table th,
.dash-table td {
  text-align: left;
  padding: 12px 16px;
  font-size: 13px;
  border-bottom: 1px solid var(--dash-border);
}

.dash-table th {
  font-weight: 600;
  color: var(--dash-text-muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  font-size: 11px;
  background: var(--dash-surface-hover);
}

.dash-table td {
  color: var(--dash-text-secondary);
}

.dash-table tr:hover td {
  background: var(--dash-surface-hover);
}

.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  font-weight: 600;
  padding: 3px 10px;
  border-radius: 20px;
}

.status-badge.success {
  background: var(--dash-accent-light);
  color: var(--dash-accent);
}

.status-badge.pending {
  background: var(--dash-warning-light);
  color: var(--dash-warning);
}

.status-badge.failed {
  background: var(--dash-danger-light);
  color: var(--dash-danger);
}

/* ════════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════════ */
@media (max-width: 1100px) {
  .stats-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .quick-actions-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .insight-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 800px) {
  .sidebar {
    width: 220px;
    min-width: 220px;
  }
  .content-area {
    padding: 24px;
  }
  .stats-grid {
    grid-template-columns: 1fr;
  }
  .quick-actions-grid {
    grid-template-columns: 1fr;
  }
  .dash-input-row {
    grid-template-columns: 1fr;
  }
  .listing-preview-shell {
    grid-template-columns: 1fr;
  }
  .listing-preview-image {
    width: 100%;
    height: 220px;
  }
  .bulk-meta-grid {
    grid-template-columns: 1fr;
  }
}

/* Login overlay */
.login-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.7);
  backdrop-filter: blur(6px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.login-card {
  background: var(--dash-surface);
  border-radius: var(--dash-radius-xl);
  padding: 48px 40px;
  text-align: center;
  max-width: 420px;
  width: 90%;
  box-shadow: var(--dash-shadow-lg);
}

.login-card h2 {
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 8px;
}

.login-card p {
  font-size: 14px;
  color: var(--dash-text-muted);
  margin-bottom: 24px;
  line-height: 1.5;
}

.hidden {
  display: none !important;
}
